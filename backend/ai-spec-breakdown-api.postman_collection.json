        },
        "description": "Test validation (missing id field - will return INVALID_ISSUES error)"
      },
    {
      "name": "10. Publish Issues (Invalid Summary - Error Demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"issues\": [\n    {\n      \"id\": \"story-1\",\n      \"key\": \"STORY-1\",\n      \"type\": \"story\",\n      \"description\": \"Test\"\n    }\n  ],\n  \"options\": {\"disableRandomErrors\": true}\n}\n"
        },
        "description": "Test validation (missing summary field - will return INVALID_ISSUES error)"
