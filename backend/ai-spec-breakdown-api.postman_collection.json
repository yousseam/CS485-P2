      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"issues\": [],\n  \"options\": {\"disableRandomErrors\": true}\n}\n"
        },
        "description": "Test validation (will return INVALID_ISSUES error)"
      },
