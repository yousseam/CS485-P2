    {
      "name": "11. Publish Issues (No Description - Error Demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"issues\": [\n    {\n      \"id\": \"story-1\",\n      \"key\": \"STORY-1\",\n      \"type\": \"story\",\n      \"summary\": \"Test\"\n      \"acceptanceCriteria\": [\"Criterion 1\"]\n    }\n  ],\n  \"options\": {\"disableRandomErrors\": true}\n}\n"
        },
        "description": "Test validation (missing description field - will return INVALID_ISSUES error)"
      },
    {
      "name": "12. Publish Issues (Invalid Array Type - Error Demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"issues\": \"not an array\",\n  \"options\": {\"disableRandomErrors\": true}\n}\n"
        },
        "description": "Test validation (issues is not an array - will return INVALID_ISSUES error)"
      },
    {
      "name": "13. Publish Issues (Force Publish Error - Demo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues"
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"issues\": [\n    {\n      \"id\": \"story-1\",\n      \"key\": \"STORY-1\",\n      \"type\": \"story\",\n      \"summary\": \"Test\",\n      \"description\": \"Test description\",\n      \"acceptanceCriteria\": [\"Criterion 1\"]\n    }\n  ],\n  \"options\": {\"forceError\": true, \"disableRandomErrors\": true}\n}\n"
        },
        "description": "Demonstrate publish error handling (will return PUBLISH_ERR)"
      },
    {
      "name": "14. Get Project Info",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues/project-info"
        },
        "description": "Get information about the configured Jira project"
      }
    },
    {
      "name": "15. Generate Issues Service Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/generate-issues/health"
        },
        "description": "Check health of the issue generation service"
      }
    },
    {
      "name": "16. Publish Issues Service Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/publish-issues/health"
        },
        "description": "Check health of the publish issues service"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001",
      "type": "string"
    }
  ]
}
