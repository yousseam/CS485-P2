{
  "name": "ai-spec-breakdown-backend",
  "version": "1.0.0",
  "description": "Backend API for AI Specification Breakdown - transforms specs into Jira issues",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "test:jest": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:jest:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/SuggestionBatch.test.js",
      "**/tasksRoutes.test.js"
    ],
    "transform": {}
  }
}
