# Server Configuration
PORT=3001
NODE_ENV=development

# API Configuration
API_BASE_URL=http://localhost:3001/api
FRONTEND_URL=http://localhost:5173

# Rate Limiting (optional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_spec_breakdown
DB_USER=postgres
DB_PASSWORD=postgres

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# AI Configuration
# Set one or both to enable AI-powered issue generation
# If neither is set, the system will fall back to mock issues

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o  # Options: gpt-4o, gpt-4o-mini, gpt-4-turbo

# Anthropic Configuration
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-sonnet-20250219  # Options: claude-3-sonnet-20250219, claude-3-opus-20250219

# Google Gemini Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-flash-latest  # Options: gemini-flash-latest, gemini-2.0-flash, etc.

# AI Provider Selection
# - gemini: always use Google Gemini (recommended for this project)
# - auto: first available key in order Gemini → OpenAI → Anthropic
# - openai | anthropic: force that provider
AI_PROVIDER=gemini

# Debugging: when true, the backend will error instead of returning mock issues
# Useful to identify why Gemini isn't generating (missing/invalid key, blocked prompt, model errors, etc.)
AI_DISABLE_MOCK=false

# Jira Configuration (for future real Jira integration)
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=ABC
