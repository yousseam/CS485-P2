# Docker Environment Variables Example
# Copy this file to .env and set your actual API keys

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration (optional - for Claude models)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini (primary provider for issue generation)
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# auto = Gemini → OpenAI → Anthropic; or force: gemini | openai | anthropic
AI_PROVIDER=gemini

# Debugging: when true, the backend will error instead of returning mock issues
# Useful to identify why Gemini isn't generating (missing/invalid key, blocked prompt, model errors, etc.)
AI_DISABLE_MOCK=false

# Database Configuration (for local development, not needed for Docker)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=ai_spec_breakdown
# DB_USER=postgres
# DB_PASSWORD=postgres

# JWT Secret (change this in production!)
JWT_SECRET=your-secret-key-change-in-production
