# Frontend Environment Variables

# API Configuration
# Set to 'true' to use the mock API instead of connecting to backend
# Useful for development and testing without backend running
VITE_USE_MOCK=false

# Backend API URL (only used when VITE_USE_MOCK=false)
# Change this if your backend runs on a different port or host
VITE_API_BASE_URL=http://localhost:3001/api
